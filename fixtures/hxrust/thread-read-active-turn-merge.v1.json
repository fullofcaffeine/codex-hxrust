        "summaryContains": "turn=turn-2;status=interrupted;items=1[userMessage:stale prompt]"
      }
    },
    {
      "id": "live-running-preserves-in-progress",
      "loadedStatus": "idle",
      "hasLiveRunningThread": true,
      "activeTurn": null,
      "expect": {
        "ok": true,
        "code": "turns_reconstructed",
        "threadStatus": "active",
        "turnCount": 2,
        "summaryContains": "merge:turns_reconstructed;ok=true;threadStatus=active;turns=2;[turn=turn-1;status=completed;items=2[userMessage:first prompt|agentMessage:first answer]||turn=turn-2;status=inProgress;items=1[userMessage:stale prompt]]"
      }
    },
    {
      "id": "active-turn-appended-before-running-observed",
      "loadedStatus": "idle",
      "hasLiveRunningThread": false,
      "activeTurn": {
        "id": "live-turn",
        "status": "inProgress",
        "items": [
          { "kind": "userMessage", "text": "live prompt" }
        ]
      },
      "expect": {
        "ok": true,
        "code": "turns_reconstructed",
        "threadStatus": "active",
        "turnCount": 3,
        "summaryContains": "turn=live-turn;status=inProgress;items=1[userMessage:live prompt]"
      }
    },
    {
      "id": "active-turn-replaces-history-copy",
      "loadedStatus": "active",
      "hasLiveRunningThread": true,
      "activeTurn": {
        "id": "turn-2",
        "status": "inProgress",
        "items": [
          { "kind": "userMessage", "text": "fresh prompt" },
          { "kind": "agentMessage", "text": "streaming answer" }
        ]
      },
      "expect": {
        "ok": true,
        "code": "turns_reconstructed",
        "threadStatus": "active",
        "turnCount": 2,
        "summaryContains": "turn=turn-1;status=completed;items=2[userMessage:first prompt|agentMessage:first answer]||turn=turn-2;status=inProgress;items=2[userMessage:fresh prompt|agentMessage:streaming answer]"
      }
    },
    {
      "id": "missing-active-snapshot-active-status",
      "loadedStatus": "active",
      "hasLiveRunningThread": false,
      "activeTurn": null,
      "expect": {
        "ok": true,
        "code": "turns_reconstructed",
        "threadStatus": "active",
        "turnCount": 2,
        "summaryContains": "turn=turn-2;status=inProgress;items=1[userMessage:stale prompt]"
      }
    },
    {
      "id": "invalid-loaded-status-refused",
      "loadedStatus": "paused",
      "hasLiveRunningThread": false,
      "activeTurn": null,
      "expect": {
        "ok": false,
        "code": "invalid_thread_status",
        "threadStatus": "notLoaded",
        "turnCount": 0,
        "summaryContains": ""
      }
